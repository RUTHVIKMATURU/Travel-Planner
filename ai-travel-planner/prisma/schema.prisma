generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Authentication (Auth.js Standard Schema)
// -----------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // For credentials auth if needed
  role          UserRole  @default(USER)
  
  accounts      Account[]
  sessions      Session[]
  
  // App Relations
  tripCollaborations TripCollaborator[]
  notifications      Notification[]
  expensesPaid       Expense[]          @relation("ExpensePayer")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Core App Data
// -----------------------------------------------------------------------------

enum TripStatus {
  DRAFT
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

model Trip {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  startDate   DateTime?
  endDate     DateTime?
  status      TripStatus @default(DRAFT)
  coverImage  String?

  // Relations
  collaborators TripCollaborator[]
  destinations  Destination[]
  budget        Budget?
  expenses      Expense[]
  packingLists  PackingList[]
  itineraries   AiItinerary[]
  savedPlaces   SavedPlace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trips")
}

enum CollaboratorRole {
  OWNER
  EDITOR
  VIEWER
}

model TripCollaborator {
  id        String           @id @default(cuid())
  tripId    String
  userId    String
  role      CollaboratorRole @default(VIEWER)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, userId]) // A user can only have one role per trip
  @@index([userId])
  @@index([tripId])
  @@map("trip_collaborators")
}

model Destination {
  id        String   @id @default(cuid())
  tripId    String
  name      String
  country   String?
  city      String?
  latitude  Float?
  longitude Float?
  order     Int      @default(0)
  startDate DateTime?
  endDate   DateTime?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("destinations")
}

model Budget {
  id       String @id @default(cuid())
  tripId   String @unique
  amount   Float
  currency String @default("USD")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budgets")
}

enum ExpenseCategory {
  FLIGHTS
  ACCOMMODATION
  TRANSPORT
  FOOD
  ACTIVITIES
  SHOPPING
  OTHER
}

model Expense {
  id          String          @id @default(cuid())
  tripId      String
  payerId     String?         // Who paid for it
  title       String
  amount      Float
  currency    String          @default("USD")
  category    ExpenseCategory @default(OTHER)
  date        DateTime
  notes       String?         @db.Text

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payer User? @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([payerId])
  @@map("expenses")
}

model PackingList {
  id     String @id @default(cuid())
  tripId String
  title  String

  items PackingItem[]

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("packing_lists")
}

model PackingItem {
  id            String  @id @default(cuid())
  packingListId String
  name          String
  quantity      Int     @default(1)
  isPacked      Boolean @default(false)

  packingList PackingList @relation(fields: [packingListId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packingListId])
  @@map("packing_items")
}

model AiItinerary {
  id         String @id @default(cuid())
  tripId     String
  prompt     String @db.Text
  content    Json   // Structured data returned from AI
  isApplied  Boolean @default(false)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("ai_itineraries")
}

model SavedPlace {
  id            String  @id @default(cuid())
  tripId        String
  googlePlaceId String?
  name          String
  address       String?
  latitude      Float?
  longitude     Float?
  category      String? // e.g., RESTAURANT, HOTEL, ATTRACTION
  notes         String? @db.Text
  url           String?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@map("saved_places")
}

// -----------------------------------------------------------------------------
// System & Caching
// -----------------------------------------------------------------------------

model WeatherCache {
  id        String   @id @default(cuid())
  latitude  Float
  longitude Float
  date      DateTime @db.Date
  data      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([latitude, longitude, date])
  @@map("weather_cache")
}

enum NotificationType {
  INVITATION
  SYSTEM
  REMINDER
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  message String           @db.Text
  read    Boolean          @default(false)
  link    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}